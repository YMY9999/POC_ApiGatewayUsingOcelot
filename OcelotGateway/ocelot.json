{
  "Routes": [
    {

      //------------products-----------------------
      "UpstreamPathTemplate": "/store/ApiGateway/products",
      "UpstreamHttpMethod": [ "Get" ],
      "DownstreamPathTemplate": "/api/products",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5001
        }
      ],
      "LoadBalancerOptions": {
        "Type": "RoundRobin"
      },
      "RateLimitOptions": {
        "EnableRateLimiting": false
      },
      "FileCacheOptions": {
        "TtlSeconds": 10,
        "Region": "products"
      },
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer",
        "AllowedScopes": []
      },
      "RouteClaimsRequirement": {
        "Role": "User"
      }
    },

    //------------Account-----------------------

    {
      "UpstreamPathTemplate": "/store/ApiGateway/Account",
      "UpstreamHttpMethod": [ "Post" ],
      "DownstreamPathTemplate": "/api/Account",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5006
        }
      ],
      "RateLimitOptions": {
        "EnableRateLimiting": false
      }
    },

    //------------stock-----------------------

    {
      "UpstreamPathTemplate": "/store/ApiGateway/stock/{productId}",
      "UpstreamHttpMethod": [ "Get" ],
      "DownstreamPathTemplate": "/api/stock/{productId}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5002
        }
      ],
      "RateLimitOptions": {
        "ClientWhitelist": [],
        "EnableRateLimiting": true,
        "Period": "10s",
        "Limit": 3
      },
      "FileCacheOptions": {
        "TtlSeconds": 10,
        "Region": "stock"
      },
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer",
        "AllowedScopes": []
      },
      "RouteClaimsRequirement": {
        "Role": "Administrator"
      }
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "http://localhost:5000",
    "RateLimitOptions": {
      "ClientIdHeader": "ClientId",
      "DisableRateLimitHeaders": false,
      "QuotaExceededMessage": "Rate limit exceeded!",
      "HttpStatusCode": 429
    }
  }
}